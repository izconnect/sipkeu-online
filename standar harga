</div>

<!-- ==================== DETAIL MODAL ==================== -->
<div class="overlay" id="overlay" onclick="closeOverlay(event)">
  <div class="modal" id="modal">
    <div class="modal-top">
      <div style="flex:1">
        <div class="modal-type-strip">
          <span class="type-chip" id="m-chip">—</span>
          <span style="font-size:11px;color:var(--text4);font-weight:500">Standar Harga 2026</span>
        </div>
        <div class="modal-title" id="m-title">—</div>
      </div>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body">
      <div class="modal-harga-box">
        <div class="modal-harga-label">Harga Satuan</div>
        <div class="modal-harga-value" id="m-harga">—</div>
        <div class="modal-satuan" id="m-satuan">per —</div>
