    <!-- ASB -->
    <div class="upload-card uc-asb" id="card-ASB" onclick="triggerUpload('ASB')">
      <div class="uc-icon">🏗️</div>
      <div class="uc-label">ASB</div>
      <div class="uc-name">Analisis Standar Belanja</div>
