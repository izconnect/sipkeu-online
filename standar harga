    </div>

    <!-- HSPK -->
    <div class="upload-card uc-hspk" id="card-HSPK" onclick="triggerUpload('HSPK')">
      <div class="uc-icon">🔧</div>
      <div class="uc-label">HSPK</div>
      <div class="uc-name">Harga Satuan Pek. Konstruksi</div>
      <div class="uc-desc">Harga satuan pekerjaan konstruksi &amp; pemeliharaan bangunan</div>
      <div class="progress-bar-wrap" id="prog-HSPK"><div class="progress-bar"></div></div>
      <div class="uc-status" id="status-HSPK">Klik atau seret file Excel di sini</div>
      <input type="file" class="uc-file-input" id="file-HSPK" accept=".xlsx,.xls" onchange="handleFile(event,'HSPK')">
    </div>
  </div>

  <button class="btn-launch" id="btnLaunch" onclick="launchApp()">
    <span>🚀</span> Buka Aplikasi Pencarian
  </button>

  <div class="upload-hints">
    <div class="hint"><div class="hint-dot" style="background:var(--cyan)"></div>Min. 1 file untuk memulai</div>
    <div class="hint"><div class="hint-dot" style="background:var(--purple)"></div>Semua data diproses lokal</div>
    <div class="hint"><div class="hint-dot" style="background:var(--teal)"></div>Format .xlsx / .xls</div>
    <div class="hint"><div class="hint-dot" style="background:var(--amber)"></div>Kolom standar: KODE KELOMPOK BARANG, URAIAN KELOMPOK BARANG, ID STANDAR HARGA, KODE BARANG, URAIAN BARANG, SPESIFIKASI, SATUAN, HARGA SATUAN, KODE REKENING</div>
  </div>
</div>

<!-- ==================== APP SCREEN ==================== -->
<div id="appScreen">

  <!-- Toolbar -->
  <div class="app-toolbar">
    <div class="search-wrap">
      <span class="s-icon">🔍</span>
      <input type="text" id="searchInput" placeholder="Cari uraian barang, kode, spesifikasi, rekening..." autocomplete="off">
    </div>
    <div class="filter-pills" id="filterPills">
      <button class="pill active-all" id="pill-ALL" onclick="setFilter('ALL')">
        <span class="pill-dot" style="background:white"></span> Semua
      </button>
      <button class="pill" id="pill-SSH" onclick="setFilter('SSH')" style="display:none">
        <span class="pill-dot" style="background:var(--cyan)"></span> SSH
      </button>
      <button class="pill" id="pill-SBU" onclick="setFilter('SBU')" style="display:none">
        <span class="pill-dot" style="background:var(--purple)"></span> SBU
      </button>
      <button class="pill" id="pill-ASB" onclick="setFilter('ASB')" style="display:none">
        <span class="pill-dot" style="background:var(--amber)"></span> ASB
      </button>
      <button class="pill" id="pill-HSPK" onclick="setFilter('HSPK')" style="display:none">
        <span class="pill-dot" style="background:var(--teal)"></span> HSPK
