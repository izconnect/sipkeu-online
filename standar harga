      <div class="modal-fields" id="m-fields"></div>
      <div class="modal-actions" id="m-actions"></div>
    </div>
  </div>
</div>

<!-- ==================== SCRIPT ==================== -->
<script>
// ======= STATE =======
const DATA = {};            // { SSH: [...], SBU: [...], ... }
let ALL_RECORDS  = [];
let FILTERED     = [];
let currentType  = 'ALL';
let currentQuery = '';
let currentPage  = 1;
const PER_PAGE   = 50;
let searchTimer;
let currentItem  = null;

// Column aliases — robust detection
const COL_MAP = {
  kode_kelompok: ['KODE KELOMPOK BARANG','KODEKELOMPOKBARANG'],
  uraian_kelompok:['URAIAN KELOMPOK BARANG','URAIANKELOMPOKBARANG'],
  id_standar:    ['ID STANDAR HARGA','IDSTANDARHARGA'],
  kode_barang:   ['KODE BARANG','KODEBARANG'],
  uraian_barang: ['URAIAN BARANG','URAIANBARANG'],
  spesifikasi:   ['SPESIFIKASI'],
  satuan:        ['SATUAN'],
  harga_satuan:  ['HARGA SATUAN','HARGASATUAN'],
  kode_rekening: ['KODE REKENING','KODEREKENING'],
};

// ======= UPLOAD =======
function triggerUpload(type) {
  document.getElementById('file-'+type).click();
}

function handleFile(event, type) {
  const file = event.target.files[0];
  if (!file) return;
  event.stopPropagation();

  setStatus(type, '⏳ Membaca file...', false);
  animateProgress(type);

  const reader = new FileReader();
  reader.onload = (e) => {
    try {
      const wb = XLSX.read(e.target.result, { type:'array' });
      const wsName = wb.SheetNames[0];
      const ws = wb.Sheets[wsName];
      const rawRows = XLSX.utils.sheet_to_json(ws, { defval:'' });

      if (rawRows.length === 0) {
        setStatus(type, '❌ Sheet kosong', false);
        return;
      }

      // Map columns flexibly
      const headers = Object.keys(rawRows[0]).map(h => h.trim().toUpperCase());
      const colIdx = {};
      for (const [key, aliases] of Object.entries(COL_MAP)) {
        for (const alias of aliases) {
          const orig = Object.keys(rawRows[0]).find(h => h.trim().toUpperCase() === alias);
          if (orig) { colIdx[key] = orig; break; }
        }
      }

      const records = rawRows.map(row => {
        const r = {};
        for (const [key, orig] of Object.entries(colIdx)) {
          r[key] = orig ? String(row[orig] ?? '').trim() : '';
        }
        r._type = type;
        return r;
      }).filter(r => r.uraian_barang || r.kode_barang);

      DATA[type] = records;
      setStatus(type, `✅ ${records.length.toLocaleString('id-ID')} item dimuat`, true);
      document.getElementById('card-'+type).classList.add('loaded');

      checkLaunchReady();
      toast(`✅ ${type}: ${records.length.toLocaleString('id-ID')} item berhasil dimuat`, 3000);

    } catch(err) {
      setStatus(type, '❌ Gagal membaca file: '+err.message, false);
      console.error(err);
    }
  };
  reader.readAsArrayBuffer(file);
}

function animateProgress(type) {
  const bar = document.querySelector('#prog-'+type+' .progress-bar');
  if (!bar) return;
  bar.style.width = '0%';
  let w = 0;
  const iv = setInterval(() => {
    w = Math.min(w + Math.random()*15, 90);
    bar.style.width = w+'%';
    if (w >= 90) clearInterval(iv);
  }, 80);
  bar._interval = iv;
}

function setStatus(type, msg, done) {
  const el = document.getElementById('status-'+type);
  if (el) el.textContent = msg;
  if (done) {
    const bar = document.querySelector('#prog-'+type+' .progress-bar');
    if (bar) { bar.style.width='100%'; clearInterval(bar._interval); }
  }
}

function checkLaunchReady() {
  const btn = document.getElementById('btnLaunch');
  const loaded = Object.keys(DATA).length;
  btn.classList.toggle('ready', loaded > 0);
}

// Drag & drop
document.querySelectorAll('.upload-card').forEach(card => {
  card.addEventListener('dragover', e => { e.preventDefault(); card.classList.add('dragover'); });
  card.addEventListener('dragleave', () => card.classList.remove('dragover'));
  card.addEventListener('drop', e => {
    e.preventDefault(); card.classList.remove('dragover');
    const type = card.id.replace('card-','');
    const file = e.dataTransfer.files[0];
    if (!file) return;
    const inp = document.getElementById('file-'+type);
    const dt = new DataTransfer();
    dt.items.add(file);
    inp.files = dt.files;
    handleFile({ target:inp, stopPropagation:()=>{} }, type);
  });
});

// ======= LAUNCH =======
function launchApp() {
  if (!Object.keys(DATA).length) return;

  // Build ALL_RECORDS
  ALL_RECORDS = [];
  const types = ['SSH','SBU','ASB','HSPK'];
  types.forEach(t => {
    if (DATA[t]) ALL_RECORDS = ALL_RECORDS.concat(DATA[t]);
  });

  // Update stats
  let total = 0;
  types.forEach(t => {
    const cnt = DATA[t] ? DATA[t].length : 0;
    const sc = document.getElementById('sc-'+t);
    const sv = document.getElementById('sv-'+t);
    const pill = document.getElementById('pill-'+t);
    if (DATA[t]) {
      sc.style.display = ''; pill.style.display = '';
      sv.textContent = cnt.toLocaleString('id-ID');
      total += cnt;
    }
  });
  document.getElementById('sv-ALL').textContent = total.toLocaleString('id-ID');

  // Show/hide screens
  document.getElementById('uploadScreen').style.display = 'none';
  document.getElementById('appScreen').style.display = 'block';

  currentType  = 'ALL';
  currentQuery = '';
  currentPage  = 1;
  doSearch();
}

// ======= SEARCH & FILTER =======
document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('searchInput').addEventListener('input', e => {
    clearTimeout(searchTimer);
    currentQuery = e.target.value;
    searchTimer = setTimeout(() => { currentPage=1; doSearch(); }, 220);
  });
});

function setFilter(type) {
  currentType = type;
  currentPage = 1;

  // Pills
  document.querySelectorAll('.pill').forEach(p => {
    p.className = 'pill';
    if (p.id === 'pill-'+type || (type==='ALL' && p.id==='pill-ALL'))
      p.className = 'pill active-'+type;
  });

  // Stat cells
  document.querySelectorAll('.stat-cell').forEach(c => {
    c.className = 'stat-cell';
    if (c.id === 'sc-'+type) c.className = 'stat-cell sc-active sc-active-'+type;
  });

  doSearch();
}

function doSearch() {
  const q = currentQuery.toLowerCase().trim();
  FILTERED = ALL_RECORDS.filter(r => {
    if (currentType !== 'ALL' && r._type !== currentType) return false;
    if (!q) return true;
    return (
      r.uraian_barang?.toLowerCase().includes(q) ||
      r.kode_barang?.toLowerCase().includes(q) ||
      r.spesifikasi?.toLowerCase().includes(q) ||
      r.uraian_kelompok?.toLowerCase().includes(q) ||
      r.kode_rekening?.toLowerCase().includes(q) ||
      r.satuan?.toLowerCase().includes(q)
    );
  });
  renderTable();
  renderPagination();
  updateMeta();
}

// ======= TABLE RENDER =======
function highlight(text, q) {
  if (!q || !text) return text || '—';
  const esc = q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&');
  return String(text).replace(new RegExp('('+esc+')','gi'),'<mark>$1</mark>');
}

function fmtRupiah(val) {
  const n = parseInt(val);
  if (isNaN(n)) return val || '—';
  return 'Rp ' + n.toLocaleString('id-ID');
}

function renderTable() {
  const tbody = document.getElementById('tableBody');
  const start = (currentPage-1)*PER_PAGE;
  const slice = FILTERED.slice(start, start+PER_PAGE);
  const q = currentQuery.toLowerCase().trim();

  if (!slice.length) {
    const msg = FILTERED.length === 0 && currentQuery
      ? `<tr><td colspan="8"><div class="empty-state"><span class="big-icon">🔎</span><h3>Tidak ditemukan</h3><p>Coba kata kunci lain atau ubah filter kategori</p></div></td></tr>`
      : `<tr><td colspan="8"><div class="empty-state"><span class="big-icon">📭</span><h3>Belum ada data</h3><p>Upload minimal satu file Excel terlebih dahulu</p></div></td></tr>`;
    tbody.innerHTML = msg;
    return;
  }

  tbody.innerHTML = slice.map((r, i) => `
    <tr onclick="showDetail(${start+i})" style="animation-delay:${Math.min(i*12,200)}ms">
      <td><span class="type-chip tc-${r._type}">${r._type}</span></td>
      <td><div class="td-kode">${r.kode_barang||'—'}</div></td>
      <td><div class="td-uraian">${highlight(r.uraian_barang, q)}</div></td>
      <td><div class="td-kelompok">${r.uraian_kelompok||'—'}</div></td>
      <td><div class="td-spek">${r.spesifikasi||'—'}</div></td>
      <td><div class="td-satuan">${r.satuan||'—'}</div></td>
      <td><div class="td-harga">${fmtRupiah(r.harga_satuan)}</div></td>
      <td><div class="td-rek">${r.kode_rekening||'—'}</div></td>
    </tr>
  `).join('');
}

function renderPagination() {
  const total = FILTERED.length;
  const totalPages = Math.ceil(total/PER_PAGE);
  const pag = document.getElementById('pageBtns');
  const info = document.getElementById('pageInfoText');

  const s = (currentPage-1)*PER_PAGE + 1;
  const e = Math.min(currentPage*PER_PAGE, total);
  info.textContent = total ? `Menampilkan ${s.toLocaleString('id-ID')}–${e.toLocaleString('id-ID')} dari ${total.toLocaleString('id-ID')} item` : 'Tidak ada data';

  if (totalPages <= 1) { pag.innerHTML=''; return; }

  let html = `<button class="pb" onclick="goPage(${currentPage-1})" ${currentPage===1?'disabled':''}>‹</button>`;

  let lo = Math.max(1, currentPage-2), hi = Math.min(totalPages, lo+4);
  if (hi-lo < 4) lo = Math.max(1, hi-4);

  if (lo > 1) html += `<button class="pb" onclick="goPage(1)">1</button><span class="pb dots">…</span>`;
  for (let i=lo; i<=hi; i++)
    html += `<button class="pb ${i===currentPage?'active':''}" onclick="goPage(${i})">${i}</button>`;
  if (hi < totalPages) html += `<span class="pb dots">…</span><button class="pb" onclick="goPage(${totalPages})">${totalPages}</button>`;

  html += `<button class="pb" onclick="goPage(${currentPage+1})" ${currentPage===totalPages?'disabled':''}>›</button>`;
  pag.innerHTML = html;
}

function goPage(p) {
  const tp = Math.ceil(FILTERED.length/PER_PAGE);
  if (p<1||p>tp) return;
  currentPage = p;
  renderTable();
  renderPagination();
  document.getElementById('appScreen').scrollIntoView({behavior:'smooth',block:'start'});
}

function updateMeta() {
  const cnt = FILTERED.length;
  const q = currentQuery;
  const typeLabel = currentType === 'ALL' ? 'semua kategori' : currentType;
  document.getElementById('metaCount').innerHTML =
    `<strong>${cnt.toLocaleString('id-ID')}</strong> hasil${q?' untuk "'+q+'"':''} &mdash; ${typeLabel}`;
}

// ======= DETAIL MODAL =======
function showDetail(globalIdx) {
  const r = FILTERED[globalIdx];
  if (!r) return;
  currentItem = r;

  document.getElementById('m-chip').textContent = r._type;
  document.getElementById('m-chip').className = 'type-chip tc-'+r._type;
  document.getElementById('m-title').textContent = r.uraian_barang || '—';
  document.getElementById('m-harga').textContent = fmtRupiah(r.harga_satuan);
  document.getElementById('m-satuan').textContent = 'per ' + (r.satuan||'—');

  document.getElementById('m-fields').innerHTML = `
    <div class="mf full">
      <div class="mf-label">Kelompok Barang</div>
      <div class="mf-value">${r.uraian_kelompok||'—'}</div>
    </div>
    <div class="mf">
      <div class="mf-label">Spesifikasi</div>
      <div class="mf-value">${r.spesifikasi||'—'}</div>
    </div>
    <div class="mf">
      <div class="mf-label">Satuan</div>
      <div class="mf-value">${r.satuan||'—'}</div>
    </div>
    <div class="mf full">
      <div class="mf-label">Kode Barang</div>
      <div class="mf-value mono">${r.kode_barang||'—'}</div>
    </div>
    <div class="mf full">
      <div class="mf-label">Kode Rekening</div>
      <div class="mf-value mono">${r.kode_rekening||'—'}</div>
    </div>
    <div class="mf">
      <div class="mf-label">Kode Kelompok</div>
      <div class="mf-value mono">${r.kode_kelompok||'—'}</div>
    </div>
    <div class="mf">
      <div class="mf-label">ID Standar Harga</div>
      <div class="mf-value mono">${r.id_standar||'—'}</div>
    </div>
  `;

  document.getElementById('m-actions').innerHTML = `
    <button class="btn-copy" onclick="copyText('${esc(r.kode_barang)}', this)">📋 Kode Barang</button>
    <button class="btn-copy" onclick="copyText('${esc(r.kode_rekening)}', this)">📋 Kode Rekening</button>
    <button class="btn-copy" onclick="copyText('${esc(fmtRupiah(r.harga_satuan))}', this)">📋 Harga</button>
    <button class="btn-copy" onclick="copyAll()" style="margin-left:auto">📋 Salin Semua</button>
  `;

  document.getElementById('overlay').classList.add('open');
}

function esc(s){ return (s||'').replace(/'/g,"\\'"); }

function closeOverlay(e){ if(e.target===document.getElementById('overlay')) closeModal(); }
function closeModal(){ document.getElementById('overlay').classList.remove('open'); }

function copyText(text, btn) {
  navigator.clipboard.writeText(text).then(() => {
    const orig = btn.innerHTML;
    btn.innerHTML = '✅ Tersalin!'; btn.classList.add('done');
    setTimeout(() => { btn.innerHTML=orig; btn.classList.remove('done'); }, 2000);
  });
}

function copyAll() {
  if (!currentItem) return;
  const r = currentItem;
  const text = [
    `Jenis       : ${r._type}`,
    `Uraian      : ${r.uraian_barang}`,
    `Kelompok    : ${r.uraian_kelompok}`,
    `Spesifikasi : ${r.spesifikasi}`,
    `Satuan      : ${r.satuan}`,
    `Harga Satuan: ${fmtRupiah(r.harga_satuan)}`,
    `Kode Barang : ${r.kode_barang}`,
    `Kode Rekening: ${r.kode_rekening}`,
    `ID Standar  : ${r.id_standar}`,
  ].join('\n');
  navigator.clipboard.writeText(text).then(() => toast('✅ Semua data disalin ke clipboard!', 2500));
}

// ======= RESET =======
function resetApp() {
  if (!confirm('Hapus semua data dan kembali ke halaman upload?')) return;
  location.reload();
}

// ======= TOAST =======
let toastTimer;
function toast(msg, dur=3000) {
  document.querySelectorAll('.toast').forEach(t=>t.remove());
  const el = document.createElement('div');
  el.className='toast'; el.textContent=msg;
  document.body.appendChild(el);
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.remove(), dur);
}

// ======= KEYBOARD =======
document.addEventListener('keydown', e => {
  if (e.key==='Escape') closeModal();
  if ((e.ctrlKey||e.metaKey) && e.key==='k') {
    e.preventDefault();
    document.getElementById('searchInput')?.focus();
  }
});
</script>
